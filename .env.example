# ── 必須 ──────────────────────────────────────────
# Discord Developer Portal で取得した Bot Token
DISCORD_TOKEN=your-discord-bot-token-here

# 投稿先チャンネルの ID（数字）
# チャンネルを右クリック → "IDをコピー" で取得
DISCORD_CHANNEL_ID=123456789012345678

# ── 任意 ──────────────────────────────────────────
# Twitter/X API Bearer Token（未設定ならTwitter収集をスキップ）
# TWITTER_BEARER_TOKEN=

# 投稿時刻（UTC）デフォルト: 0:00 UTC = JST 9:00
# POST_HOUR=0
# POST_MINUTE=0
